{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taohtml.local/evals/cross-agent/run-result.schema.json",
  "title": "TaoHtml cross-Agent authenticated black-box result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_contract_version",
    "evaluated_at",
    "run",
    "audit",
    "automatic_status",
    "human_review",
    "overall_status",
    "checks",
    "claims",
    "provenance"
  ],
  "properties": {
    "result_contract_version": {"const": "taohtml-cross-agent-result-2"},
    "evaluated_at": {"type": "string", "minLength": 1},
    "run": {"$ref": "#/$defs/run"},
    "audit": {"$ref": "#/$defs/audit"},
    "automatic_status": {"enum": ["PASS", "FAIL"]},
    "human_review": {"$ref": "#/$defs/human_review"},
    "overall_status": {"enum": ["PASS", "FAIL", "AWAITING_HUMAN"]},
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["participant_integrity"],
      "properties": {
        "participant_integrity": {"$ref": "#/$defs/check"},
        "profile_routing": {"$ref": "#/$defs/check"},
        "design_brief_binding": {"$ref": "#/$defs/check"},
        "report_ir": {"$ref": "#/$defs/check"},
        "compiler_manifest_html": {"$ref": "#/$defs/check"},
        "project_handoff": {"$ref": "#/$defs/check"},
        "qa_boundary": {"$ref": "#/$defs/check"},
        "technical_evaluation": {"$ref": "#/$defs/check"}
      }
    },
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_evaluator_used",
        "network_used",
        "workbuddy_run_executed_by_this_script",
        "visual_aesthetics_automatically_passed",
        "actual_presentation_effect_automatically_passed"
      ],
      "properties": {
        "model_evaluator_used": {"const": false},
        "network_used": {"const": false},
        "workbuddy_run_executed_by_this_script": {"const": false},
        "visual_aesthetics_automatically_passed": {"const": false},
        "actual_presentation_effect_automatically_passed": {"const": false}
      }
    },
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "nonce",
        "scenario_id",
        "target_platform",
        "created_at",
        "source_commit",
        "input_tree_sha256"
      ],
      "properties": {
        "run_id": {"type": "string", "minLength": 3},
        "nonce": {"type": "string", "pattern": "^[a-f0-9]{32,128}$"},
        "scenario_id": {"type": "string", "minLength": 3},
        "target_platform": {"enum": ["codex", "workbuddy"]},
        "created_at": {"type": "string", "minLength": 1},
        "source_commit": {"type": "string", "minLength": 1},
        "input_tree_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "token_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "source", "input", "output", "cache", "total"],
      "properties": {
        "availability": {"enum": ["exact", "unknown"]},
        "source": {"type": "string", "minLength": 1},
        "input": {"type": ["number", "null"], "minimum": 0},
        "output": {"type": ["number", "null"], "minimum": 0},
        "cache": {"type": ["number", "null"], "minimum": 0},
        "total": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "point_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["availability", "source", "value", "balance_before", "balance_after"],
      "properties": {
        "availability": {"enum": ["exact", "unknown"]},
        "source": {"type": "string", "minLength": 1},
        "value": {"type": ["number", "null"], "minimum": 0},
        "balance_before": {"type": ["number", "null"], "minimum": 0},
        "balance_after": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "agent",
        "model",
        "started_at",
        "ended_at",
        "tokens",
        "points",
        "validation_issues",
        "used_for_automatic_pass"
      ],
      "properties": {
        "platform": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "started_at": {"type": ["string", "null"]},
        "ended_at": {"type": ["string", "null"]},
        "tokens": {"$ref": "#/$defs/token_usage"},
        "points": {"$ref": "#/$defs/point_usage"},
        "validation_issues": {"type": "array", "items": {"type": "string"}},
        "used_for_automatic_pass": {"const": false}
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "note"],
      "properties": {
        "status": {"enum": ["PASS", "FAIL", "PENDING"]},
        "note": {"type": "string"}
      }
    },
    "human_review": {
      "type": "object",
      "required": ["status", "dimensions", "source"],
      "properties": {
        "review_version": {"const": "1.0"},
        "scenario_id": {"type": "string"},
        "run_id": {"type": "string"},
        "status": {"enum": ["PASS", "FAIL", "PENDING", "INVALID"]},
        "dimensions": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/dimension"}
        },
        "reviewer": {"type": "string"},
        "reviewed_at": {"type": "string"},
        "source": {"type": ["string", "null"]},
        "issues": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": ["status"],
      "properties": {"status": {"enum": ["PASS", "FAIL"]}},
      "additionalProperties": true
    },
    "returned_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sha256"],
      "properties": {
        "kind": {"enum": ["zip", "directory_tree"]},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controller_receipt_sha256",
        "run_manifest_sha256",
        "answer_key_sha256",
        "participant_zip_sha256",
        "returned_artifact",
        "acceptance_toolchain_sha256",
        "result_hmac_sha256"
      ],
      "properties": {
        "controller_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "run_manifest_sha256": {"$ref": "#/$defs/sha256"},
        "answer_key_sha256": {"$ref": "#/$defs/sha256"},
        "participant_zip_sha256": {"$ref": "#/$defs/sha256"},
        "returned_artifact": {"$ref": "#/$defs/returned_artifact"},
        "acceptance_toolchain_sha256": {"$ref": "#/$defs/sha256"},
        "result_hmac_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
