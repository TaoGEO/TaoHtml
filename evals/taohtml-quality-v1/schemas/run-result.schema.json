{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/taohtml/quality-benchmark-v1/run-result.schema.json",
  "title": "TaoHtml quality benchmark v1 run result",
  "type": "object",
  "required": ["schema_version", "run", "objective", "human", "failure_samples", "comparison"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run": {
      "type": "object",
      "required": ["id", "scenario_id", "client", "agent", "model", "skill", "started_at", "ended_at", "question_count", "token_usage", "billing_usage", "duration"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "scenario_id": {"enum": ["idea-live-conversion", "pdf-evidence-report", "existing-html-upgrade"]},
        "client": {"type": "string", "minLength": 1},
        "agent": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "skill": {
          "type": "object",
          "required": ["version", "commit"],
          "properties": {
            "version": {"type": "string", "minLength": 1},
            "commit": {"type": "string", "minLength": 1}
          }
        },
        "started_at": {"type": "string"},
        "ended_at": {"type": "string"},
        "question_count": {"type": "integer", "minimum": 0},
        "token_usage": {"$ref": "#/$defs/token_usage"},
        "billing_usage": {"$ref": "#/$defs/billing_usage"},
        "duration": {"$ref": "#/$defs/duration"}
      }
    },
    "objective": {
      "type": "object",
      "required": ["status", "hard_failure_count", "checks"],
      "properties": {
        "status": {"enum": ["pass", "conditional", "fail", "unavailable"]},
        "artifact_status": {"enum": ["pass", "fail", "unavailable"]},
        "hard_failure_count": {"type": "integer", "minimum": 0},
        "warning_count": {"type": "integer", "minimum": 0},
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "category", "status", "hard_failure", "summary", "evidence"],
            "properties": {
              "id": {"type": "string"},
              "category": {"type": "string"},
              "status": {"enum": ["pass", "warning", "fail", "unavailable"]},
              "hard_failure": {"type": "boolean"},
              "scope": {"enum": ["artifact", "workflow"]},
              "summary": {"type": "string"},
              "evidence": {}
            }
          }
        }
      }
    },
    "human": {"$ref": "#/$defs/human_review"},
    "failure_samples": {"type": "array", "items": {"type": "object"}},
    "comparison": {
      "type": "object",
      "required": ["comparable", "benchmark_success", "note"],
      "properties": {
        "comparable": {"type": "boolean"},
        "benchmark_success": {"type": "boolean"},
        "artifact_usable": {"type": "boolean"},
        "workflow_status": {"enum": ["pass", "conditional", "fail", "unavailable"]},
        "note": {"type": "string"}
      }
    }
  },
  "$defs": {
    "token_usage": {
      "type": "object",
      "required": ["availability", "source", "input_tokens", "output_tokens", "cache_tokens", "total_tokens"],
      "properties": {
        "availability": {"enum": ["exact", "unavailable"]},
        "source": {"enum": ["platform_task_usage", "manual", "unavailable"]},
        "input_tokens": {"type": ["integer", "null"], "minimum": 0},
        "output_tokens": {"type": ["integer", "null"], "minimum": 0},
        "cache_tokens": {"type": ["integer", "null"], "minimum": 0},
        "total_tokens": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "billing_usage": {
      "type": "object",
      "required": ["availability", "source", "workbuddy_points", "balance_before", "balance_after"],
      "properties": {
        "availability": {"enum": ["exact", "unavailable"]},
        "source": {"enum": ["platform_task_usage", "balance_delta", "manual", "unavailable"]},
        "workbuddy_points": {"type": ["number", "null"], "minimum": 0},
        "balance_before": {"type": ["number", "null"], "minimum": 0},
        "balance_after": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "duration": {
      "type": "object",
      "required": ["status", "seconds"],
      "properties": {
        "status": {"enum": ["available", "unavailable"]},
        "seconds": {"type": ["number", "null"], "minimum": 0}
      }
    },
    "human_review": {
      "type": "object",
      "required": ["status", "reviewer", "reviewed_at", "dimensions", "manual_revision_count", "reference_floor", "notes", "failure_samples"],
      "properties": {
        "status": {"enum": ["complete", "pending"]},
        "reviewer": {"type": "string"},
        "reviewed_at": {"type": ["string", "null"]},
        "dimensions": {
          "type": "object",
          "required": ["story_progression", "page_role_clarity", "composition_hierarchy", "layout_repetition", "evidence_readability", "motion_support", "overall_finish"],
          "additionalProperties": {
            "type": "object",
            "required": ["score", "note"],
            "properties": {
              "score": {"type": ["integer", "null"], "minimum": 1, "maximum": 5},
              "note": {"type": "string"}
            }
          }
        },
        "manual_revision_count": {"type": ["integer", "null"], "minimum": 0},
        "reference_floor": {
          "type": "object",
          "required": ["status", "note"],
          "properties": {
            "status": {"enum": ["below", "matches", "exceeds", "unavailable"]},
            "note": {"type": "string"}
          }
        },
        "notes": {"type": "string"},
        "failure_samples": {"type": "array", "items": {"type": "object"}}
      }
    }
  }
}
